Byte-compiled / cache
__pycache__/
*.pyc
*.pyo

# Cython build artifacts (firmware_v1_5/*.c 是固件源码, 不挡)
build/
*.so
*.pyd.orig

# Data - never commit raw CWRU or any signal data (递归挡子目录)
data/**/*.mat
data/**/*.npz
data/**/*.csv
data/*.mat
data/*.npz
data/*.csv
!data/README.md

# Outputs
# 实验产物 (CSV/PNG/MD/TXT) 是仓库价值的一部分, 允许进 git.
# 只挡掉临时对照实验和缓存.
outputs/cache/
outputs/scratch/
outputs/*.npz

# Scratch scripts (对照实验, 不进 git)
experiments/scratch_*.py

# Local model weights (LLM 权重, 不含固件 model.h)
llm/models/
llm/weights/
*.safetensors

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Env
.env
*.env
venv/
.venv/

# Video assets (托管在 GitHub user-attachments, 不进 git)
firmware_v1_5/assets/*.mp4
firmware_v1_5/assets/*.mov
firmware_v1_5/assets/*.webm
