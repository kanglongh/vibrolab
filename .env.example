# vibrolab · 环境变量示例
# ============================================================
# 用法:
#   1. cp .env.example .env      (或在 Windows: copy .env.example .env)
#   2. 填入下方各变量的真实值
#   3. 加载到当前 shell:
#        Linux/Mac:   set -a && source .env && set +a
#        Windows cmd: for /f "usebackq tokens=1,* delims==" %i in (".env") do @if not "%i"=="" if not "%i:~0,1%"=="#" set "%i=%j"
#        PowerShell:  Get-Content .env | ForEach-Object { if($_ -match '^\s*([^#=][^=]*)=(.*)$'){ [System.Environment]::SetEnvironmentVariable($Matches[1].Trim(), $Matches[2].Trim()) } }
#
# 注意: .env 文件已被 .gitignore 排除, 请勿提交任何真实密钥到 git.
# ============================================================


# ============================================================
# 云端 LLM 后端 (可选, 用于 exp06b_llm_diagnosis_api.py)
# ============================================================
# vibrolab 的云端 LLM 后端遵循 OpenAI Chat Completions 协议,
# 只要服务商暴露 /v1/chat/completions 端点即可对接:
#   · 阿里云百炼    (兼容 OpenAI 协议入口)
#   · DeepSeek
#   · 智谱 GLM      (bigmodel 平台)
#   · Moonshot Kimi
#   · OpenAI 官方
#   · vLLM / Ollama 自部署
# 只需切换下面四个变量, 无需改任何代码.
# ============================================================

# ---- 必填三件套 ----
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.7-max

# ---- 可选: 服务商展示名 (仅用于生成报告的落款, 不影响调用) ----
LLM_PROVIDER=阿里云百炼

# ---- 可选: 成本核算 (元 / 百万 token) ----
# 例: 阿里云百炼 qwen3.7-max 输入 12, 输出 36
#     DeepSeek deepseek-chat  输入  2, 输出   8
#     不设置则报告里成本记为 0, 不影响功能
LLM_PRICE_IN=12
LLM_PRICE_OUT=36


# ============================================================
# 其他常见服务商配置参考 (取消注释一段即可切换)
# ============================================================
# --- DeepSeek ---
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
# LLM_PROVIDER=DeepSeek
# LLM_PRICE_IN=2
# LLM_PRICE_OUT=8

# --- 智谱 GLM ---
# LLM_API_KEY=xxx.xxx
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4-plus
# LLM_PROVIDER=智谱 AI
# LLM_PRICE_IN=50
# LLM_PRICE_OUT=50

# --- Moonshot Kimi ---
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=moonshot-v1-8k
# LLM_PROVIDER=Moonshot Kimi

# --- OpenAI 官方 ---
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_PROVIDER=OpenAI

# --- 自部署 vLLM / Ollama ---
# LLM_API_KEY=EMPTY
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_MODEL=Qwen2.5-7B-Instruct
# LLM_PROVIDER=本地 vLLM


# ============================================================
# 本地 LLM 后端 (可选, 用于 exp06_llm_diagnosis.py)
# ============================================================
# 指向本地下载的模型目录 (包含 config.json / *.safetensors 等)
# QWEN_MODEL_PATH=D:\models\Qwen2.5-0.5B-Instruct


# ============================================================
# LLM 后端切换 (可选)
# ============================================================
# 未设置时默认使用本地后端; 显式设为 'api' 走云端 OpenAI-Compatible 后端
# LLM_BACKEND=local
